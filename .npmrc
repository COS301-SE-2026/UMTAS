# Hoist shared dev tooling so ESLint plugins, TypeScript, and type definitions
# resolve correctly across workspace packages without phantom dependency issues.
hoist=true
hoist-pattern[]=*eslint*
hoist-pattern[]=*prettier*
hoist-pattern[]=*typescript*
hoist-pattern[]=@types/*
hoist-pattern[]=*jest*
hoist-pattern[]=ts-jest
hoist-pattern[]=ts-node
hoist-pattern[]=tsconfig-paths

# NestJS decorators and DI require reflect-metadata and @nestjs/* packages to
# resolve from the root node_modules.
public-hoist-pattern[]=reflect-metadata
public-hoist-pattern[]=*@nestjs/*
