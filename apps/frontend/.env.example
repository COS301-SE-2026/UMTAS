# =========================================================
# Frontend environment - Next.js
# Copy to .env.local: cp .env.example .env.local
# =========================================================

# Backend URL - server-side only (Next.js RSC / API routes → NestJS direct)
API_URL=http://localhost:3000

# Backend base URL - browser-facing. In dev, proxied via Next.js rewrites.
# In prod, set to https://api.DOMAIN (direct backend; required for OAuth state cookies).
NEXT_PUBLIC_API_URL=http://localhost:3001
