# =========================================================
# Frontend environment - Next.js
# Copy to .env.local: cp .env.example .env.local
# =========================================================

# Backend URL - server-side only (Next.js RSC / API routes → NestJS direct)
API_URL=http://localhost:3000

# Backend auth URL - browser-facing (proxied via Next.js rewrites at /api/auth)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/auth

# Frontend public URL
NEXT_PUBLIC_APP_URL=http://localhost:3001
