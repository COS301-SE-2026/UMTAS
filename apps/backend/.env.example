# =========================================================
# Backend environment - NestJS / Drizzle / Better Auth
# Copy to .env.local: cp .env.example .env.local
# =========================================================

# ---- Database ----
# DB_MODE=PGLITE    → in-process SQLite-compatible DB (no postgres container needed)
# DB_MODE=DATABASE  → uses postgres (requires DATABASE_URL below)
DB_MODE=PGLITE

# Only required when DB_MODE=DATABASE
# Match DB_USER / DB_PASSWORD / DB_NAME from root .env
DATABASE_URL=there_was_a_lint_problem

# ---- Seeding ----
SEED=TRUE
SEED_TASKS=default-system-admin
SEED_SYSTEM_ADMIN_NAME=System Admin
SEED_SYSTEM_ADMIN_EMAIL=system-admin@local.umtas
SEED_SYSTEM_ADMIN_PASSWORD=Admin@UMTAS2024!
SEED_TEST_PASSWORD=Test@UMTAS2024!

# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Redis (optional in dev - falls back to in-memory rate limiting) ----
# Required in production
REDIS_URL=redis://localhost:6379

# ---- Better Auth ----
BETTER_AUTH_SECRET=replace_with_32plus_char_secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# ---- Google OAuth (optional - leave blank to disable) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- System admins (comma-separated user IDs) ----
SYSTEM_ADMIN_USER_IDS=seed-system-admin

# ---- Email ----
# Development (MailHog on localhost):
#   MAIL_HOST=localhost, MAIL_PORT=1025, MAIL_SECURE=false
#   MAIL_SERVICE=, MAIL_USER=, MAIL_PASS=, MAIL_FROM=noreply@umtas.co.za
# Production (Gmail with App Password):
#   MAIL_SERVICE=gmail, MAIL_USER=your_email@gmail.com, MAIL_PASS=<16-char app password>, MAIL_FROM=UMTAS <your_email@gmail.com>
# Testing (Ethereal fake SMTP sandbox):
#   MAIL_SERVICE=Ethereal, MAIL_USER=<generated>, MAIL_PASS=<generated>, MAIL_FROM=test@example.com
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_SERVICE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=UMTAS <noreply@umtas.co.za>

# ---- CORS ----
CORS_ORIGIN=http://localhost:3001
