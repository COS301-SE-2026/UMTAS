# Database configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/umtas
DB_MODE=DATABASE # Allowed: PGLITE | DATABASE
SEED=FALSE # Allowed: TRUE | FALSE
SEED_TASKS=default-system-admin # Optional comma-separated seed task list
SEED_SYSTEM_ADMIN_NAME=System Admin
SEED_SYSTEM_ADMIN_EMAIL=system-admin@local.umtas
NODE_ENV=development

# Redis (optional for session caching + rate limiting)
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=replace_with_32plus_char_secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# System admins (comma-separated user IDs)
SYSTEM_ADMIN_USER_IDS=

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=UMTAS <noreply@umtas.co.za>

# CORS
CORS_ORIGIN=http://localhost:3001
