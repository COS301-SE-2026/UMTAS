# Database configuration
# DB_MODE=PGLITE  # Uncomment for in-process PGlite (local dev, no Postgres needed)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/umtas
DB_MODE=DATABASE # Allowed: PGLITE | DATABASE
SEED=FALSE # Allowed: TRUE | FALSE
SEED_TASKS=default-system-admin  # Comma-separated list; omit to run all seeds (default-system-admin,auth-seed)
SEED_SYSTEM_ADMIN_NAME=System Admin
SEED_SYSTEM_ADMIN_EMAIL=system-admin@local.umtas
SEED_SYSTEM_ADMIN_PASSWORD=Admin@UMTAS2024!
SEED_TEST_PASSWORD=Test@UMTAS2024!
NODE_ENV=development

# Redis (optional for session caching + rate limiting)
# REDIS_URL=  # Required when NODE_ENV=production; omit only for local dev (rate limit falls back to memory)
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=replace_with_32plus_char_secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# System admins (comma-separated user IDs — include seed-system-admin for local dev)
SYSTEM_ADMIN_USER_IDS=seed-system-admin

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=UMTAS <noreply@umtas.co.za>

# CORS
CORS_ORIGIN=http://localhost:3001
