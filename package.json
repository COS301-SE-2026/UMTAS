{
  "name": "UMTAS",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:infra": "docker compose up -d postgres redis minio solver",
    "dev:monitor": "docker compose --profile dev-docker --profile monitoring up",
    "dev:pglite": "docker compose --profile dev-pglite up --build",
    "dev:docker": "docker compose --profile dev-docker up --build",
    "start:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "start:server": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile server up -d --build",
    "build": "turbo run build",
    "setup": "scripts/bootstrap.sh",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged",
    "ci": "turbo run ci",
    "prepare": "husky install",
    "act": "act --container-architecture linux/amd64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.4",
    "@types/handlebars": "^4.1.0",
    "@types/nodemailer": "^8.0.0",
    "dotenv": "^16.0.3",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,scss}": "prettier --write"
  }
}
