{
  "name": "UMTAS",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:infra": "docker compose up -d postgres redis minio solver",
    "dev:monitor": "docker compose --profile dev-docker --profile monitoring up --build",
    "dev:pglite": "docker compose --profile dev-pglite up --build",
    "dev:docker": "docker compose --profile dev-docker up --build",
    "start:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "start:server": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile server up -d --build",
    "build": "turbo run build",
    "setup": "scripts/bootstrap.sh",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged",
    "ci": "turbo run ci",
    "prepare": "husky",
    "act": "act push -j ci --container-architecture linux/amd64"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "secretlint": "^13.0.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^16.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,scss}": "prettier --write",
    "apps/frontend/**/*.{js,jsx,ts,tsx}": "eslint --fix --config apps/frontend/eslint.config.mjs",
    "apps/backend/**/*.{js,ts}": "eslint --fix --config apps/backend/eslint.config.mjs",
    "**/*": "secretlint"
  }
}
