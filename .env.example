# =========================================================
# Root environment — docker-compose + shared dev config
# Copy to .env: cp .env.example .env
# =========================================================

# Infrastructure
PROJECT_NAME=umtas
DOCKER_REGISTRY=vigilcs/umtas

# Traefik dashboard auth — generate with:
# htpasswd -nb admin YOUR_PASSWORD | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$replace$$withtherealhashedvalue

# Docker Hub — used by Watchtower to pull private images
DOCKERHUB_USERNAME=vigilcs
DOCKERHUB_TOKEN=your-dockerhub-access-token

# Ports (docker container ports, not necessarily what's exposed to host)
BACKEND_PORT=3000
FRONTEND_PORT=3001

# Database (used by docker-compose postgres service)
DB_USER=capstone_admin
DB_PASSWORD=change_me_long_and_random
DB_NAME=umtas_db

# Storage (Minio)
MINIO_ROOT_USER=storage_admin
MINIO_ROOT_PASSWORD=change_me_another_secure_password

# Monitoring
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# Caching
REDIS_PASSWORD=change_me_redis_password

# ---- Backend runtime vars (also read by NestJS in local dev) ----

# DB mode: PGLITE (in-process, no postgres needed) | DATABASE (uses postgres container)
DB_MODE=PGLITE

# Seeding
SEED=TRUE
SEED_TASKS=default-system-admin
SEED_SYSTEM_ADMIN_NAME=System Admin
SEED_SYSTEM_ADMIN_EMAIL=system-admin@local.umtas
SEED_SYSTEM_ADMIN_PASSWORD=Admin@UMTAS2024!
SYSTEM_ADMIN_USER_IDS=seed-system-admin

# App
NODE_ENV=development
PORT=3000
BETTER_AUTH_SECRET=replace_with_32plus_character_secret_key
BETTER_AUTH_URL=http://localhost:3000/api/auth
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api/auth

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
