# =========================================================
# Root environment - docker-compose + shared dev config
# Copy to .env: cp .env.example .env
# =========================================================

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
DOMAIN=capstone-vigil.dns.net.za
LETSENCRYPT_EMAIL=yourname@gmail.com

PROJECT_NAME=umtas
DOCKER_REGISTRY=vigilcs/umtas
# dev = tracks dev branch builds, latest = tracks main branch builds
IMAGE_TAG=dev

# Generate with: htpasswd -nb admin YOUR_PASSWORD | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$replace$$withtherealhashedvalue

# -----------------------------------------------------------------------------
# Docker Hub
# -----------------------------------------------------------------------------
DOCKERHUB_USERNAME=vigilcs
DOCKERHUB_TOKEN=your-dockerhub-access-token

WATCHTOWER_DISCORD_URL=discord://TOKEN@WEBHOOK_ID
WATCHTOWER_HTTP_API_TOKEN=your-watchtower-api-token

# -----------------------------------------------------------------------------
# Ports (internal Docker only - not exposed publicly)
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_USER=capstone_admin
DB_PASSWORD=replace_with_long_random_string
DB_NAME=umtas_db

# DB mode: PGLITE (in-process, no postgres needed) | DATABASE (uses postgres container)
DB_MODE=DATABASE

# -----------------------------------------------------------------------------
# Storage (MinIO - S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=storage_admin
MINIO_ROOT_PASSWORD=replace_with_long_random_string

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=replace_with_long_random_string

# -----------------------------------------------------------------------------
# Monitoring (Grafana)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=replace_with_long_random_string

# -----------------------------------------------------------------------------
# Backend application (Better Auth)
# -----------------------------------------------------------------------------
NODE_ENV=production
BETTER_AUTH_SECRET=replace_with_32_plus_char_random_string
BETTER_AUTH_URL=https://api.your-domain.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://your-domain.example.com
CORS_ORIGIN=https://your-domain.example.com

# Google OAuth (optional - leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (SMTP)
# Source of truth for Docker runs (docker-compose reads this file).
# Use MAIL_* to switch providers without changing code.
# -----------------------------------------------------------------------------
# MailHog (dev)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_SERVICE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=UMTAS <noreply@umtas.co.za>

# Gmail (prod, App Password)
# MAIL_SERVICE=gmail
# MAIL_USER=your_email@gmail.com
# MAIL_PASS=<16-char app password>

# -----------------------------------------------------------------------------
# Seeding
# -----------------------------------------------------------------------------
SEED=FALSE
SEED_TASKS=default-system-admin
SEED_SYSTEM_ADMIN_NAME=System Admin
SEED_SYSTEM_ADMIN_EMAIL=system-admin@local.umtas
SEED_SYSTEM_ADMIN_PASSWORD=Admin@UMTAS2024!
SEED_TEST_PASSWORD=Test@UMTAS2024!
SYSTEM_ADMIN_USER_IDS=seed-system-admin
