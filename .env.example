# Infrastructure
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=yourname@gmail.com
PROJECT_NAME=umtas
DOCKER_REGISTRY=vigilcs/umtas

# Traefik dashboard auth — generate with:
# htpasswd -nb admin YOUR_PASSWORD | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$replace$$withtherealhashedvalue

# Docker Hub — used by Watchtower to pull private images
DOCKERHUB_USERNAME=vigilcs
DOCKERHUB_TOKEN=your-dockerhub-access-token

# Ports (Internal only)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database
DB_USER=capstone_admin
DB_PASSWORD=make_this_very_long_and_random
DB_NAME=umtas_db

# Storage (Minio)
MINIO_ROOT_USER=storage_admin
MINIO_ROOT_PASSWORD=another_secure_password

# Monitoring
GRAFANA_ADMIN_PASSWORD=super_secret_grafana

# Caching
REDIS_PASSWORD=another_secure_password

# Database Mode & Auth
DB_MODE=PGLITE
SEED=TRUE
BETTER_AUTH_SECRET=your-secret-key-here
