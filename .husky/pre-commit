# Block direct commits to protected branches
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ] || [ "$BRANCH" = "dev" ]; then
  echo "Direct commits to '$BRANCH' are not allowed. Use a feature branch and open a PR."
  exit 1
fi

pnpm run lint-staged

# Type check only the apps that have staged TypeScript files
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACMR | grep -E 'apps/(frontend|backend)/.*\.(ts|tsx)$' || true)

if echo "$STAGED_TS" | grep -q 'apps/frontend/'; then
  echo "Running frontend type check..."
  pnpm -C apps/frontend exec tsc --noEmit
fi

if echo "$STAGED_TS" | grep -q 'apps/backend/'; then
  echo "Running backend type check..."
  pnpm -C apps/backend exec tsc --noEmit
fi
